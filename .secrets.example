# Copy to `.secrets` at the repo root and fill in values from the Nhost Dashboard.
# Local defaults below are for `nhost up` only — cloud values live in the Dashboard.

HASURA_GRAPHQL_ADMIN_SECRET=your-hasura-admin-secret
NHOST_WEBHOOK_SECRET=your-webhook-secret
GRAFANA_ADMIN_PASSWORD=grafana-admin-password

# Copy to `.secrets` at the repo root and fill in values from the Nhost Dashboard.
# Local defaults below are for `nhost up` only — cloud values live in the Dashboard.

HASURA_GRAPHQL_ADMIN_SECRET=your-hasura-admin-secret
NHOST_WEBHOOK_SECRET=your-webhook-secret
GRAFANA_ADMIN_PASSWORD=grafana-admin-password

# JWT (RS256) — required for Function JWT auth (auth/* session probe, mobile clients).
# cam-app-admin BFF uses HASURA_GRAPHQL_ADMIN_SECRET via x-hasura-admin-secret instead.
NHOST_JWT_KID=your-jwt-kid
NHOST_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
NHOST_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Guest PWA base URL (used by admin/events/get-qr to build join links)
GUEST_APP_URL=http://localhost:3001

# Client portal base URL (used by admin/clients/* for invite links)
CLIENT_APP_URL=http://localhost:3002

# Nhost Storage bucket for media uploads
MEDIA_STORAGE_BUCKET=cam-bucket
